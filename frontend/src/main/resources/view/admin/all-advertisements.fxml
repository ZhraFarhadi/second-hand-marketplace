<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.frontend.controller.admin.AllAdvertisementsController">

    <top>

        <ToolBar>

            <Button text="← Home"
                    onAction="#goDashboard"/>

            <Label text="All Advertisements"/>

        </ToolBar>

    </top>

    <center>

        <TableView fx:id="advertisementsTable">

            <columns>

                <TableColumn fx:id="titleColumn"
                             text="Title"
                             prefWidth="280"/>

                <TableColumn fx:id="sellerColumn"
                             text="Seller"
                             prefWidth="170"/>

                <TableColumn fx:id="categoryColumn"
                             text="Category"
                             prefWidth="150"/>

                <TableColumn fx:id="cityColumn"
                             text="City"
                             prefWidth="140"/>

                <TableColumn fx:id="priceColumn"
                             text="Price"
                             prefWidth="130"/>

                <TableColumn fx:id="statusColumn"
                             text="Status"
                             prefWidth="120"/>

                <TableColumn fx:id="actionColumn"
                             text="Action"
                             prefWidth="120"/>

            </columns>

        </TableView>

    </center>

</BorderPane>