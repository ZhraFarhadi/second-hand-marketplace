<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.frontend.controller.admin.AdvertisementReviewController">

    <top>
        <fx:include source="../components/header.fxml"/>
    </top>

    <center>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    styleClass="content-scroll">

            <StackPane alignment="TOP_CENTER">

                <HBox alignment="TOP_CENTER"
                      spacing="45"
                      maxWidth="1280"
                      prefWidth="1280">

                    <padding>
                        <Insets top="35"
                                right="35"
                                bottom="40"
                                left="35"/>
                    </padding>

                    <!-- ================= LEFT ================= -->

                    <VBox spacing="25"
                          prefWidth="560"
                          alignment="TOP_CENTER">

                        <StackPane styleClass="main-image-container">

                            <ImageView fx:id="mainImageView"
                                       fitWidth="560"
                                       fitHeight="560"
                                       preserveRatio="true"/>

                        </StackPane>

                        <ScrollPane fitToHeight="true"
                                    fitToWidth="false"
                                    hbarPolicy="AS_NEEDED"
                                    vbarPolicy="NEVER"
                                    pannable="true"
                                    styleClass="gallery-scroll">

                            <HBox fx:id="thumbnailContainer"
                                  spacing="10"
                                  alignment="CENTER_LEFT"/>

                            <padding>
                                <Insets top="5"
                                        right="5"
                                        bottom="5"
                                        left="5"/>
                            </padding>

                        </ScrollPane>

                        <VBox spacing="18"
                              prefWidth="560"
                              styleClass="seller-card">

                            <padding>
                                <Insets top="22"
                                        right="22"
                                        bottom="22"
                                        left="22"/>
                            </padding>

                            <Label text="Seller"
                                   styleClass="seller-title"/>

                            <Label fx:id="sellerNameLabel"
                                   styleClass="seller-name"/>

                            <Label fx:id="sellerRateLabel"
                                   styleClass="seller-rate"/>

                        </VBox>

                    </VBox>

                    <!-- ================= RIGHT ================= -->

                    <VBox spacing="24"
                          prefWidth="650"
                          alignment="TOP_LEFT">

                        <HBox spacing="12"
                              alignment="CENTER_LEFT">

                            <Button text="←"
                                    onAction="#back"
                                    styleClass="back-button"/>

                            <Label fx:id="titleLabel"
                                   wrapText="true"
                                   maxWidth="590"
                                   styleClass="detail-title"/>

                        </HBox>

                        <HBox alignment="CENTER_LEFT"
                              spacing="12">

                            <Label text="Price :"
                                   styleClass="price-caption"/>

                            <Label fx:id="priceLabel"
                                   styleClass="detail-price"/>

                        </HBox>

                        <HBox alignment="CENTER_LEFT"
                              spacing="18">

                            <Label fx:id="cityLabel"
                                   styleClass="detail-info"/>

                            <Label text="•"/>

                            <Label fx:id="timeLabel"
                                   styleClass="detail-info"/>

                        </HBox>

                        <Separator/>

                        <Label text="Specifications"
                               styleClass="section-title"/>

                        <VBox fx:id="attributesContainer"
                              spacing="12"/>

                        <Separator/>

                        <Label text="Description"
                               styleClass="section-title"/>

                        <VBox spacing="12"
                              prefWidth="650"
                              styleClass="description-card">

                            <padding>
                                <Insets top="22"
                                        right="24"
                                        bottom="22"
                                        left="24"/>
                            </padding>

                            <Label fx:id="descriptionLabel"
                                   wrapText="true"
                                   maxWidth="600"
                                   styleClass="description-text"/>

                        </VBox>

                        <Separator/>

                        <VBox fx:id="reviewActionsBox" spacing="18">

                            <Label text="Reject Reason"
                                   styleClass="section-title"/>

                            <TextArea fx:id="rejectReasonField"
                                      promptText="Reason for rejection..."
                                      prefRowCount="5"
                                      wrapText="true"/>

                            <HBox spacing="18"
                                  alignment="CENTER_LEFT">

                                <Button text="Approve"
                                        onAction="#approveAdvertisement"/>

                                <Button text="Reject"
                                        onAction="#rejectAdvertisement"/>

                            </HBox>

                        </VBox>

                        <HBox fx:id="deleteActionsBox"
                              spacing="18"
                              alignment="CENTER_LEFT"
                              visible="false"
                              managed="false">

                            <Button text="حذف آگهی"
                                    onAction="#deleteAdvertisement"
                                    style="-fx-text-fill: white; -fx-background-color: #d9534f;"/>

                        </HBox>

                    </VBox>

                </HBox>

            </StackPane>

        </ScrollPane>

    </center>

</BorderPane>