<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="conversation-root"
            fx:controller="com.secondhand.frontend.controller.conversation.ConversationListController">

    <top>

        <HBox alignment="CENTER_LEFT"
              nodeOrientation="LEFT_TO_RIGHT"
              styleClass="conversation-topbar">

            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <Button fx:id="backButton"
                    text="←"
                    onAction="#onBackClicked"
                    styleClass="chat-back-button"/>

        </HBox>

    </top>

    <center>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    styleClass="conversation-scroll">

            <content>

                <StackPane alignment="TOP_CENTER"
                           nodeOrientation="RIGHT_TO_LEFT">

                    <VBox maxWidth="700"
                          prefWidth="700"
                          spacing="18">

                        <padding>
                            <Insets top="30" right="20" bottom="40" left="20"/>
                        </padding>

                        <Label text="پیام‌ها"
                               styleClass="page-title"/>

                        <VBox fx:id="conversationsContainer"
                              spacing="12"/>

                    </VBox>

                </StackPane>

            </content>

        </ScrollPane>

    </center>

</BorderPane>