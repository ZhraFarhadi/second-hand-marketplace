<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.conversation.ConversationItemController"
      fx:id="root"
      spacing="14"
      alignment="CENTER_LEFT"
      styleClass="conversation-item">

    <padding>
        <Insets top="14" right="16" bottom="14" left="16"/>
    </padding>

    <StackPane styleClass="conversation-avatar">
        <Label fx:id="avatarLabel" text="👤" styleClass="conversation-avatar-label"/>
    </StackPane>

    <VBox spacing="4" HBox.hgrow="ALWAYS">

        <HBox spacing="8" alignment="CENTER_LEFT">

            <Label fx:id="userLabel"
                   styleClass="conversation-user"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="timeLabel"
                   styleClass="conversation-time"/>

        </HBox>

        <Label fx:id="titleLabel"
               styleClass="conversation-ad"/>

        <HBox spacing="8" alignment="CENTER_LEFT">

            <Label fx:id="lastMessageLabel"
                   styleClass="conversation-message"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="unreadLabel"
                   styleClass="conversation-unread"/>

        </HBox>

    </VBox>

</HBox>