<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.frontend.controller.home.HomeController">

    <!-- ================= HEADER ================= -->

    <top>

        <fx:include
                fx:id="header"
                source="../components/header.fxml"/>


    </top>

    <!-- ================= SIDEBAR ================= -->

    <left>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    styleClass="sidebar-scroll">

            <VBox prefWidth="280"
                  spacing="15"
                  styleClass="sidebar">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Categories"
                       styleClass="section-title"/>

                <VBox fx:id="categoryContainer"
                      spacing="8"/>

                <Separator/>

                <VBox fx:id="quickAccessSection" spacing="15">

                    <Label text="Quick Access"
                           styleClass="section-title"/>

                    <Button fx:id="favoritesButton"
                            text="❤ Favorites"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                    <Button fx:id="myAdvertisementsButton"
                            text="📦 My Advertisements"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                    <Button fx:id="chatButton"
                            text="💬 Chats"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                </VBox>

                <VBox fx:id="adminSection"
                      spacing="10"
                      visible="false"
                      managed="false">

                    <Label text="مدیریت ادمین"
                           styleClass="section-title"/>

                    <Button fx:id="reviewAdvertisementsButton"
                            text="🔍 بررسی آگهی‌ها"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                    <Button fx:id="allAdvertisementsButton"
                            text="📋 لیست کل آگهی‌ها"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                    <Button fx:id="usersButton"
                            text="👤 یوزرها"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                    <Button fx:id="categoriesButton"
                            text="🗂 کتگوری و اتریبیوت‌ها"
                            maxWidth="Infinity"
                            styleClass="category-button"/>

                    <Separator/>

                    <Label text="آمار کلی سیستم"
                           styleClass="section-title"/>

                    <GridPane hgap="10" vgap="8">

                        <Label text="کاربران:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalUsersLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="کاربران مسدود:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="statsBlockedUsersLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="کل آگهی‌ها:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalAdsLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="در انتظار بررسی:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="statsPendingAdsLabel" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="آگهی‌های فعال:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="statsActiveAdsLabel" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="آگهی‌های فروخته‌شده:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label fx:id="statsSoldAdsLabel" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Label text="دسته‌بندی‌ها:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalCategoriesLabel" text="-" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                        <Label text="شهرها:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalCitiesLabel" text="-" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                        <Label text="استان‌ها:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalProvincesLabel" text="-" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                        <Label text="امتیازها:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalRatingsLabel" text="-" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                        <Label text="گفتگوها:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                        <Label fx:id="statsTotalConversationsLabel" text="-" GridPane.rowIndex="10" GridPane.columnIndex="1"/>

                    </GridPane>

                </VBox>

            </VBox>

        </ScrollPane>

    </left>

    <!-- ================= CONTENT ================= -->

    <center>

        <ScrollPane fitToWidth="true"
                    styleClass="content-scroll">

            <FlowPane fx:id="advertisementContainer"
                      hgap="22"
                      vgap="22"
                      prefWrapLength="1200">
                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>
            </FlowPane>

        </ScrollPane>

    </center>

</BorderPane>