<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            xmlns:components="com.secondhand.frontend.controller.components"
            fx:controller="com.secondhand.frontend.controller.auth.LoginController">

    <center>

        <VBox alignment="CENTER"
              spacing="30"
              styleClass="root-container">

            <!-- Logo بعداً اینجا قرار می‌گیرد -->

            <Label text="Marketplace"
                   styleClass="title"/>

            <VBox alignment="CENTER"
                  spacing="15"
                  maxWidth="320"
                  styleClass="form-container">

                <fx:include
                        fx:id="usernameComponent"
                        source="../components/floating-text-field.fxml"/>

                <Label
                        fx:id="usernameErrorLabel"
                        text="Username cannot be empty."
                        styleClass="error-label"
                        visible="false"
                        managed="false"/>



                <fx:include
                        fx:id="passwordComponent"
                        source="../components/floating-password-field.fxml"/>
                <Label
                        fx:id="passwordErrorLabel"
                        text="Password cannot be empty."
                        styleClass="error-label"
                        visible="false"
                        managed="false"/>



                <Button
                        fx:id="loginButton"
                        text="Login"
                        styleClass="login-button"
                        onAction="#handleLogin"/>

                <HBox alignment="CENTER"
                      spacing="5">

                    <Label text="Don't have an account?"
                           styleClass="normal-label"/>

                    <Hyperlink text="Register"
                               styleClass="register-link"
                               onAction="#onRegisterClicked"/>

                </HBox>

            </VBox>

        </VBox>

    </center>

</BorderPane>